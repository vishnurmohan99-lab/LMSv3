// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  FACULTY
  ADMIN
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  fullName        String
  role            Role     @default(STUDENT)
  isMentor        Boolean  @default(false)
  mentorSpecialty String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  courses           Course[]            @relation("FacultyCourses")
  questionBanks     QuestionBank[]      @relation("FacultyQuestionBanks")
  tests             Test[]              @relation("FacultyTests")
  enrollments       Enrollment[]
  flashcardProgress FlashcardProgress[]
  chatMessages      ChatMessage[]
  batchesAsFaculty  Batch[]             @relation("BatchFaculty")
  batchEnrollments  BatchEnrollment[]
  bulkOperations    BulkOperation[]

  conversationsCreated    Conversation[]            @relation("ConversationCreatedBy")
  conversationParticipant ConversationParticipant[]
  messagesSent             Message[]
  messageRecipients        MessageRecipient[]
  scheduledMessages         ScheduledMessage[]
  testAttempts              TestAttempt[]

  mentorAvailabilities    MentorAvailability[] @relation("MentorAvailabilities")
  mentorBookingsAsStudent MentorBooking[]      @relation("MentorBookingsAsStudent")
  mentorBookingsAsMentor  MentorBooking[]      @relation("MentorBookingsAsMentor")
}

model Course {
  id           String   @id @default(uuid())
  title        String   @unique
  description  String   @default("")
  thumbnailUrl String?
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  facultyId String
  faculty   User   @relation("FacultyCourses", fields: [facultyId], references: [id])

  segmentId String?
  segment   Segment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)

  subsegmentId String?
  subsegment   Subsegment? @relation(fields: [subsegmentId], references: [id], onDelete: SetNull)

  chapters      Chapter[]
  enrollments   Enrollment[]
  batches       Batch[]
  conversations Conversation[]
  mockTests     Test[]

  @@index([segmentId])
  @@index([subsegmentId])
}

model Segment {
  id        String   @id @default(uuid())
  name      String   @unique
  order     Int      @default(0)
  bannerUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subsegments Subsegment[]
  courses     Course[]
}

model Subsegment {
  id        String   @id @default(uuid())
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  segmentId String
  segment   Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  courses Course[]

  @@unique([segmentId, name])
}

model Chapter {
  id        String  @id @default(uuid())
  title     String
  order     Int     @default(0)
  bannerUrl String?

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  lessons Lesson[]
  tests   Test[]
}

enum LessonType {
  VIDEO
  PDF
  LIVE
  FLASHCARD
}

model Lesson {
  id                String     @id @default(uuid())
  title             String
  order             Int        @default(0)
  type              LessonType
  contentUrl        String?
  liveAt            DateTime?
  flashcardsEnabled Boolean    @default(false)
  aiNotesEnabled    Boolean    @default(false)
  askMeEnabled      Boolean    @default(false)
  transcript        String?    @db.Text
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  flashcards   Flashcard[]
  note         LessonNote?
  chatMessages ChatMessage[]
  sessions     Session[]
}

model LessonNote {
  id        String   @id @default(uuid())
  summary   String   @db.Text
  keyPoints String[] @default([])
  updatedAt DateTime @updatedAt

  lessonId String @unique
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

enum ChatRole {
  USER
  ASSISTANT
}

model ChatMessage {
  id        String   @id @default(uuid())
  role      ChatRole
  content   String   @db.Text
  createdAt DateTime @default(now())

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([lessonId, studentId, createdAt])
}

enum FlashcardStatus {
  NEW
  LEARNING
  KNOWN
}

model Flashcard {
  id    String @id @default(uuid())
  front String
  back  String
  order Int    @default(0)

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  progress FlashcardProgress[]
}

model FlashcardProgress {
  id             String          @id @default(uuid())
  status         FlashcardStatus @default(NEW)
  lastReviewedAt DateTime?

  studentId   String
  student     User      @relation(fields: [studentId], references: [id])
  flashcardId String
  flashcard   Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([studentId, flashcardId])
}

model Enrollment {
  id         String   @id @default(uuid())
  studentId  String
  student    User     @relation(fields: [studentId], references: [id])
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@unique([studentId, courseId])
}

model BatchStatusType {
  id                 String   @id @default(uuid())
  name               String   @unique
  color              String?
  order              Int      @default(0)
  isDefault          Boolean  @default(false)
  isCompletionTarget Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  batches Batch[]
}

model Batch {
  id        String    @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  statusId String
  status   BatchStatusType @relation(fields: [statusId], references: [id], onDelete: Restrict)

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  facultyId String?
  faculty   User?   @relation("BatchFaculty", fields: [facultyId], references: [id])

  enrollments   BatchEnrollment[]
  sessions      Session[]
  conversations Conversation[]

  @@unique([courseId, name])
}

enum BulkOperationType {
  BATCH_ENROLL
}

model BulkOperation {
  id        String            @id @default(uuid())
  type      BulkOperationType
  payload   Json
  createdAt DateTime          @default(now())
  undoneAt  DateTime?

  createdBy String
  user      User   @relation(fields: [createdBy], references: [id])
}

model BatchEnrollment {
  id              String    @id @default(uuid())
  joinedAt        DateTime  @default(now())
  accessExpiresAt DateTime?

  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  batchId String
  batch   Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, studentId])
}

enum SessionStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
  RESCHEDULED
}

model Session {
  id            String        @id @default(uuid())
  title         String
  scheduledAt   DateTime
  durationMin   Int
  status        SessionStatus @default(SCHEDULED)
  actualStartAt DateTime?
  actualEndAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  batchId String
  batch   Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  lessonId String?
  lesson   Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
}

model QuestionBank {
  id          String   @id @default(uuid())
  title       String   @unique
  description String   @default("")
  bannerUrl   String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  facultyId String
  faculty   User   @relation("FacultyQuestionBanks", fields: [facultyId], references: [id])

  questions Question[]
}

enum QuestionType {
  MCQ
  FILL_BLANK
  ESSAY
  TRUE_FALSE
}

model Question {
  id     String       @id @default(uuid())
  type   QuestionType
  prompt String
  order  Int          @default(0)

  options       String[] @default([])
  correctOption String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questionBankId String
  questionBank   QuestionBank @relation(fields: [questionBankId], references: [id], onDelete: Cascade)
}

enum TestPublishMode {
  MANUAL
  TIMED
}

model Test {
  id              String          @id @default(uuid())
  title           String          @unique
  description     String          @default("")
  bannerUrl       String?
  published       Boolean         @default(false)
  publishMode     TestPublishMode @default(MANUAL)
  availableFrom   DateTime?
  availableUntil  DateTime?
  durationMinutes Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  facultyId String
  faculty   User   @relation("FacultyTests", fields: [facultyId], references: [id])

  chapterId String?
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  testQuestions TestQuestion[]
  attempts      TestAttempt[]

  @@index([courseId])
}

model TestQuestion {
  id     String       @id @default(uuid())
  type   QuestionType
  prompt String
  order  Int          @default(0)

  options       String[] @default([])
  correctOption String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  answers TestAnswer[]
}

enum ConversationType {
  DIRECT
  COURSE_BROADCAST
  BATCH_BROADCAST
  GROUP
}

model Conversation {
  id        String           @id @default(uuid())
  type      ConversationType
  createdAt DateTime         @default(now())

  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("ConversationCreatedBy", fields: [createdById], references: [id])

  participants ConversationParticipant[]
  messages     Message[]
  scheduledMessages ScheduledMessage[]

  @@index([courseId])
  @@index([batchId])
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id        String   @id @default(uuid())
  body      String   @db.Text
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation(fields: [senderId], references: [id])

  recipients MessageRecipient[]

  @@index([conversationId, createdAt])
}

model MessageRecipient {
  id     String    @id @default(uuid())
  readAt DateTime?

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, readAt])
}

model ScheduledMessage {
  id     String    @id @default(uuid())
  body   String    @db.Text
  sendAt DateTime
  sentAt DateTime?

  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation(fields: [senderId], references: [id])

  @@index([sendAt, sentAt])
}

enum TestAttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

model TestAttempt {
  id          String            @id @default(uuid())
  status      TestAttemptStatus @default(IN_PROGRESS)
  score       Int?
  maxScore    Int?
  startedAt   DateTime          @default(now())
  submittedAt DateTime?

  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  answers TestAnswer[]

  @@index([testId, studentId])
}

model TestAnswer {
  id             String   @id @default(uuid())
  selectedOption String?
  isCorrect      Boolean?

  attemptId String
  attempt   TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  testQuestionId String
  testQuestion   TestQuestion @relation(fields: [testQuestionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, testQuestionId])
}

model MentorAvailability {
  id        String   @id @default(uuid())
  dayOfWeek Int
  time      String
  createdAt DateTime @default(now())

  mentorId String
  mentor   User   @relation("MentorAvailabilities", fields: [mentorId], references: [id], onDelete: Cascade)

  bookings MentorBooking[]

  @@unique([mentorId, dayOfWeek, time])
}

model MentorBooking {
  id          String    @id @default(uuid())
  date        DateTime
  createdAt   DateTime  @default(now())
  cancelledAt DateTime?

  availabilityId String
  availability   MentorAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

  mentorId String
  mentor   User   @relation("MentorBookingsAsMentor", fields: [mentorId], references: [id])

  studentId String
  student   User   @relation("MentorBookingsAsStudent", fields: [studentId], references: [id])

  @@unique([availabilityId, date])
  @@index([studentId])
  @@index([mentorId])
}
