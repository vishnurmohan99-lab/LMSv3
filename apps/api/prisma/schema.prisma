// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  FACULTY
  ADMIN
}

enum PlanItemType {
  VIDEO
  NOTES
  TEST
  PRACTICE
  OTHER
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  fullName        String
  role            Role     @default(STUDENT)
  isMentor        Boolean  @default(false)
  mentorSpecialty String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  segmentId String?
  segment   Segment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)

  subsegmentId String?
  subsegment   Subsegment? @relation(fields: [subsegmentId], references: [id], onDelete: SetNull)

  privateCourseAccess   CoursePrivateAccess[]
  subscriptionEnrollments SubscriptionEnrollment[]

  courses           Course[]            @relation("FacultyCourses")
  questionBanks     QuestionBank[]      @relation("FacultyQuestionBanks")
  tests             Test[]              @relation("FacultyTests")
  enrollments       Enrollment[]
  courseReviews     CourseReview[]
  createdNotesBanks NotesBank[]         @relation("CreatedNotesBanks")
  createdPlanItems  StudyPlanItem[]     @relation("PlanItemCreatedBy")
  planItems         StudyPlanItem[]     @relation("PlanItemStudent")
  flashcardProgress FlashcardProgress[]
  chatMessages      ChatMessage[]
  batchesAsFaculty  Batch[]             @relation("BatchFaculty")
  batchEnrollments  BatchEnrollment[]
  bulkOperations    BulkOperation[]

  conversationsCreated    Conversation[]            @relation("ConversationCreatedBy")
  conversationParticipant ConversationParticipant[]
  messagesSent             Message[]
  messageRecipients        MessageRecipient[]
  scheduledMessages         ScheduledMessage[]
  testAttempts              TestAttempt[]

  mentorAvailabilities    MentorAvailability[] @relation("MentorAvailabilities")
  mentorBookingsAsStudent MentorBooking[]      @relation("MentorBookingsAsStudent")
  mentorBookingsAsMentor  MentorBooking[]      @relation("MentorBookingsAsMentor")

  todos       Todo[]       @relation("Todos")
  reflections Reflection[] @relation("Reflections")

  feedbackFormsCreated  FeedbackForm[]     @relation("FeedbackFormCreatedBy")
  feedbackFormsAsTarget FeedbackForm[]     @relation("FeedbackFormTargetFaculty")
  feedbackRecipient     FeedbackRecipient[]
  feedbackResponses     FeedbackResponse[]

  forumThreads    ForumThread[]
  forumPosts      ForumPost[]
  forumThreadLikes ForumThreadLike[]
  forumCategoriesCreated ForumCategory[]     @relation("ForumCategoryCreatedBy")
  forumCategoryPermissions ForumCategoryUser[]

  chapterCompletions ChapterCompletion[]
  lessonViews        LessonView[]

  answerQuestionTypes     AnswerQuestionType[] @relation("FacultyAnswerQuestionTypes")
  answerQuestions         AnswerQuestion[]     @relation("FacultyAnswerQuestions")
  answerSubmissions       AnswerSubmission[]   @relation("AnswerSubmissions")
  gradedAnswerEvaluations AnswerEvaluation[]   @relation("AnswerEvaluationGradedBy")
}

enum CourseType {
  FREE
  PAID
  PRIVATE
}

/// Catalog difficulty. Nullable on Course — an unset course is genuinely "not rated"
/// rather than silently defaulted, so the catalog filter never claims more than it knows.
enum CourseDifficulty {
  EASY
  MEDIUM
  HARD
}

enum DripType {
  NONE
  CALENDAR
  ENROLLMENT_RELATIVE
  SEQUENTIAL
}

enum CompletionRule {
  MANUAL
  ALL_LESSONS_VIEWED
  PASS_TEST
}

model Course {
  id             String         @id @default(uuid())
  title          String         @unique
  description    String         @default("")
  thumbnailUrl   String?
  published      Boolean        @default(false)
  type           CourseType     @default(FREE)
  difficulty     CourseDifficulty?  // null = not rated; catalog hides the badge and excludes it from level filters
  priceCents      Int?          // null/0 or type=FREE → shown as "Free"; else ₹(priceCents/100)
  durationMinutes Int?          // manual estimate for catalog display ("X hrs")
  dripType       DripType       @default(NONE)
  completionRule CompletionRule @default(MANUAL)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  facultyId String
  faculty   User   @relation("FacultyCourses", fields: [facultyId], references: [id])

  segmentId String?
  segment   Segment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)

  subsegmentId String?
  subsegment   Subsegment? @relation(fields: [subsegmentId], references: [id], onDelete: SetNull)

  chapters         Chapter[]
  enrollments      Enrollment[]
  reviews          CourseReview[]
  notes            Note[]
  conversations    Conversation[]
  mockTests        Test[]
  feedbackForms    FeedbackForm[]
  forumCategories  ForumCategory[]
  privateAccess    CoursePrivateAccess[]
  subscriptionCourses SubscriptionCourse[]

  @@index([segmentId])
  @@index([subsegmentId])
}

model CoursePrivateAccess {
  id String @id @default(uuid())

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([courseId, studentId])
}

model Segment {
  id        String   @id @default(uuid())
  name      String   @unique
  order     Int      @default(0)
  bannerUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subsegments Subsegment[]
  courses     Course[]
  tests       Test[]
  students    User[]
  batches     Batch[]
}

model Subsegment {
  id        String   @id @default(uuid())
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  segmentId String
  segment   Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  courses  Course[]
  tests    Test[]
  students User[]
  batches  Batch[]

  @@unique([segmentId, name])
}

model Chapter {
  id        String    @id @default(uuid())
  title     String
  order     Int       @default(0)
  bannerUrl String?
  unlockAt        DateTime?
  unlockAfterDays Int?

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  lessons     Lesson[]
  tests       Test[]
  completions ChapterCompletion[]
  notes       Note[]
}

model ChapterCompletion {
  id String @id @default(uuid())

  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  completedAt DateTime @default(now())

  @@unique([chapterId, studentId])
}

model LessonView {
  id String @id @default(uuid())

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  viewedAt DateTime @default(now())

  @@unique([lessonId, studentId])
  // The admin segment report groups progress by (student, course); the unique index
  // above leads with lessonId so it can't serve that. viewedAt narrows the report to
  // students active in the selected window instead of scanning all history.
  @@index([studentId])
  @@index([viewedAt])
}

enum LessonType {
  VIDEO
  PDF
  LIVE
  FLASHCARD
}

model Lesson {
  id                String     @id @default(uuid())
  title             String
  order             Int        @default(0)
  type              LessonType
  contentUrl        String?
  liveAt            DateTime?
  flashcardsEnabled  Boolean    @default(false)
  aiNotesEnabled     Boolean    @default(false)
  askMeEnabled       Boolean    @default(false)
  summaryDeckEnabled Boolean    @default(false)
  cheatSheetEnabled  Boolean    @default(false)
  transcript         String?    @db.Text
  captionsVtt        String?    @db.Text
  videoChapters      String?    @db.Text
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  flashcards   Flashcard[]
  note         LessonNote?
  summaryDeck  SummaryDeck?
  cheatSheet   CheatSheet?
  chatMessages ChatMessage[]
  sessions     Session[]
  views        LessonView[]
}

model SummaryDeck {
  id        String   @id @default(uuid())
  cards     String[] @default([])
  updatedAt DateTime @updatedAt

  lessonId String @unique
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model CheatSheet {
  id             String   @id @default(uuid())
  pages          Json // CheatSheetPage[] -- { title, bullets[], table?, examTip?, illustrationKey? }
  posterImageKey String? // optional manually-uploaded full poster image (R2 key), shown uncropped
  updatedAt      DateTime @updatedAt

  lessonId String @unique
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model LessonNote {
  id        String   @id @default(uuid())
  summary   String   @db.Text
  keyPoints String[] @default([])
  updatedAt DateTime @updatedAt

  lessonId String @unique
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

enum ChatRole {
  USER
  ASSISTANT
}

model ChatMessage {
  id        String   @id @default(uuid())
  role      ChatRole
  content   String   @db.Text
  createdAt DateTime @default(now())

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([lessonId, studentId, createdAt])
}

enum FlashcardStatus {
  NEW
  LEARNING
  KNOWN
}

model Flashcard {
  id    String @id @default(uuid())
  front String
  back  String
  order Int    @default(0)

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  progress FlashcardProgress[]
}

model FlashcardProgress {
  id             String          @id @default(uuid())
  status         FlashcardStatus @default(NEW)
  lastReviewedAt DateTime?

  // Spaced repetition (SM-2 style). `intervalDays` 0 means "still in the learning
  // step" — those cards come back within the same session via a minutes-level dueAt.
  intervalDays Int       @default(0)
  ease         Float     @default(2.5)
  reps         Int       @default(0)
  dueAt        DateTime?

  studentId   String
  student     User      @relation(fields: [studentId], references: [id])
  flashcardId String
  flashcard   Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([studentId, flashcardId])
}

enum EnrollmentSource {
  SELF
  BATCH
  SUBSCRIPTION
  ADMIN
}

model Enrollment {
  id         String           @id @default(uuid())
  studentId  String
  student    User             @relation(fields: [studentId], references: [id])
  courseId   String
  course     Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrolledAt DateTime         @default(now())
  source     EnrollmentSource @default(SELF)

  @@unique([studentId, courseId])
}

model BatchStatusType {
  id                 String   @id @default(uuid())
  name               String   @unique
  color              String?
  order              Int      @default(0)
  isDefault          Boolean  @default(false)
  isCompletionTarget Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  batches Batch[]
}

model Batch {
  id        String    @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  statusId String
  status   BatchStatusType @relation(fields: [statusId], references: [id], onDelete: Restrict)

  segmentId String?
  segment   Segment? @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  subsegmentId String?
  subsegment   Subsegment? @relation(fields: [subsegmentId], references: [id], onDelete: Cascade)

  facultyId String?
  faculty   User?   @relation("BatchFaculty", fields: [facultyId], references: [id])

  enrollments   BatchEnrollment[]
  sessions      Session[]
  conversations Conversation[]
  feedbackForms FeedbackForm[]
  forumCategories ForumCategory[]
  notesBankLinks NotesBankBatch[]
  planItems     StudyPlanItem[]

  @@index([segmentId])
  @@index([subsegmentId])
}

enum BulkOperationType {
  BATCH_ENROLL
}

model BulkOperation {
  id        String            @id @default(uuid())
  type      BulkOperationType
  payload   Json
  createdAt DateTime          @default(now())
  undoneAt  DateTime?

  createdBy String
  user      User   @relation(fields: [createdBy], references: [id])
}

model BatchEnrollment {
  id              String    @id @default(uuid())
  joinedAt        DateTime  @default(now())
  accessExpiresAt DateTime?

  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  batchId String
  batch   Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, studentId])
}

enum SessionStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
  RESCHEDULED
}

model Session {
  id            String        @id @default(uuid())
  title         String
  scheduledAt   DateTime
  durationMin   Int
  status        SessionStatus @default(SCHEDULED)
  actualStartAt DateTime?
  actualEndAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  batchId String
  batch   Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  lessonId String?
  lesson   Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
}

model QuestionBank {
  id          String   @id @default(uuid())
  title       String   @unique
  description String   @default("")
  bannerUrl   String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  facultyId String
  faculty   User   @relation("FacultyQuestionBanks", fields: [facultyId], references: [id])

  questions Question[]
}

enum QuestionType {
  MCQ
  FILL_BLANK
  ESSAY
  TRUE_FALSE
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

/** Global, reusable topic tag. A tag created on one question is available to every other. */
model Tag {
  id            String         @id @default(uuid())
  name          String         @unique
  createdAt     DateTime       @default(now())
  questions     Question[]
  testQuestions TestQuestion[]
}

model Passage {
  id        String   @id @default(uuid())
  text      String   @db.Text
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions     Question[]
  testQuestions TestQuestion[]
}

model Question {
  id       String       @id @default(uuid())
  type     QuestionType
  prompt   String
  order    Int          @default(0)
  imageUrl String?

  options       String[] @default([])
  correctOption String?

  difficulty        QuestionDifficulty @default(MEDIUM)
  marks             Int                @default(1)
  negativeMarks     Float              @default(0)
  answerTimeSeconds Int?
  tags              Tag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questionBankId String
  questionBank   QuestionBank @relation(fields: [questionBankId], references: [id], onDelete: Cascade)

  passageId String?
  passage   Passage? @relation(fields: [passageId], references: [id], onDelete: SetNull)

  @@index([passageId])
}

enum TestPublishMode {
  MANUAL
  TIMED
}

model Test {
  id              String          @id @default(uuid())
  title           String          @unique
  description     String          @default("")
  bannerUrl       String?
  order           Int             @default(0)
  type            TestType        @default(FREE)
  published       Boolean         @default(false)
  publishMode     TestPublishMode @default(MANUAL)
  availableFrom   DateTime?
  availableUntil  DateTime?
  durationMinutes Int?
  passPercent     Int             @default(50)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  facultyId String
  faculty   User   @relation("FacultyTests", fields: [facultyId], references: [id])

  chapterId String?
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  segmentId String?
  segment   Segment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)

  subsegmentId String?
  subsegment   Subsegment? @relation(fields: [subsegmentId], references: [id], onDelete: SetNull)

  testQuestions TestQuestion[]
  attempts      TestAttempt[]
  subscriptions SubscriptionTest[]

  @@index([courseId])
  @@index([segmentId])
  @@index([subsegmentId])
}

enum TestType {
  FREE
  PAID
}

model TestQuestion {
  id       String       @id @default(uuid())
  type     QuestionType
  prompt   String
  order    Int          @default(0)
  imageUrl String?

  options       String[] @default([])
  correctOption String?

  difficulty        QuestionDifficulty @default(MEDIUM)
  marks             Int                @default(1)
  negativeMarks     Float              @default(0)
  answerTimeSeconds Int?
  tags              Tag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  passageId String?
  passage   Passage? @relation(fields: [passageId], references: [id], onDelete: SetNull)

  answers TestAnswer[]

  @@index([passageId])
}

enum ConversationType {
  DIRECT
  COURSE_BROADCAST
  BATCH_BROADCAST
  GROUP
}

model Conversation {
  id        String           @id @default(uuid())
  type      ConversationType
  createdAt DateTime         @default(now())

  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("ConversationCreatedBy", fields: [createdById], references: [id])

  participants ConversationParticipant[]
  messages     Message[]
  scheduledMessages ScheduledMessage[]

  @@index([courseId])
  @@index([batchId])
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id        String   @id @default(uuid())
  body      String   @db.Text
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation(fields: [senderId], references: [id])

  recipients MessageRecipient[]

  @@index([conversationId, createdAt])
}

model MessageRecipient {
  id     String    @id @default(uuid())
  readAt DateTime?

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, readAt])
}

model ScheduledMessage {
  id     String    @id @default(uuid())
  body   String    @db.Text
  sendAt DateTime
  sentAt DateTime?

  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation(fields: [senderId], references: [id])

  @@index([sendAt, sentAt])
}

enum TestAttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

model TestAttempt {
  id          String            @id @default(uuid())
  status      TestAttemptStatus @default(IN_PROGRESS)
  score       Int?
  maxScore    Int?
  startedAt   DateTime          @default(now())
  submittedAt DateTime?

  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  answers TestAnswer[]

  @@index([testId, studentId])
}

model TestAnswer {
  id             String   @id @default(uuid())
  selectedOption String?
  isCorrect      Boolean?

  attemptId String
  attempt   TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  testQuestionId String
  testQuestion   TestQuestion @relation(fields: [testQuestionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, testQuestionId])
}

model MentorAvailability {
  id        String   @id @default(uuid())
  dayOfWeek Int
  time      String
  createdAt DateTime @default(now())

  mentorId String
  mentor   User   @relation("MentorAvailabilities", fields: [mentorId], references: [id], onDelete: Cascade)

  bookings MentorBooking[]

  @@unique([mentorId, dayOfWeek, time])
}

model MentorBooking {
  id          String    @id @default(uuid())
  date        DateTime
  createdAt   DateTime  @default(now())
  cancelledAt DateTime?

  availabilityId String
  availability   MentorAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

  mentorId String
  mentor   User   @relation("MentorBookingsAsMentor", fields: [mentorId], references: [id])

  studentId String
  student   User   @relation("MentorBookingsAsStudent", fields: [studentId], references: [id])

  @@unique([availabilityId, date])
  @@index([studentId])
  @@index([mentorId])
}

model Todo {
  id        String   @id @default(uuid())
  date      DateTime
  text      String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation("Todos", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Reflection {
  id        String   @id @default(uuid())
  date      DateTime
  wentWell  String?
  toImprove String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentId String
  student   User   @relation("Reflections", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([date])
}

enum AiFeature {
  FLASHCARDS
  NOTES
  SUMMARY_DECK
  CHEAT_SHEET_TEXT
  CHEAT_SHEET_IMAGE
  CHAT
  ANSWER_GRADING
}

enum AiProvider {
  OPENROUTER
  OPENAI
}

model AiFeatureSetting {
  feature   AiFeature  @id
  provider  AiProvider @default(OPENROUTER)
  model     String?
  updatedAt DateTime   @updatedAt
}

enum FeedbackTargetType {
  COURSE
  FACULTY
  MENTOR
  SYSTEM
}

enum FeedbackAssignType {
  BATCH
  SELECTED
}

model FeedbackForm {
  id               String             @id @default(uuid())
  title            String
  targetType       FeedbackTargetType
  targetSystemArea String?
  questions        Json
  assignType       FeedbackAssignType
  createdAt        DateTime           @default(now())

  targetCourseId String?
  targetCourse   Course? @relation(fields: [targetCourseId], references: [id], onDelete: Cascade)

  targetFacultyId String?
  targetFaculty   User?   @relation("FeedbackFormTargetFaculty", fields: [targetFacultyId], references: [id])

  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("FeedbackFormCreatedBy", fields: [createdById], references: [id])

  recipients FeedbackRecipient[]
  responses  FeedbackResponse[]
}

model FeedbackRecipient {
  id String @id @default(uuid())

  formId String
  form   FeedbackForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  @@unique([formId, studentId])
}

model FeedbackResponse {
  id          String   @id @default(uuid())
  answers     Json
  submittedAt DateTime @default(now())

  formId String
  form   FeedbackForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  @@unique([formId, studentId])
}

enum ForumScopeType {
  BATCH
  COURSE
  GENERAL
}

enum ForumAccessMode {
  ALL
  SELECTED
  NONE
}

enum ForumPermissionPurpose {
  AUDIENCE
  POST
  COMMENT
}

model ForumCategory {
  id        String         @id @default(uuid())
  name      String
  scopeType ForumScopeType
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // Only meaningful for GENERAL — BATCH/COURSE categories' audience is implicitly that batch/course's members.
  audienceFacultyMode ForumAccessMode @default(ALL)
  audienceStudentMode ForumAccessMode @default(ALL)

  postFacultyMode ForumAccessMode @default(ALL)
  postStudentMode ForumAccessMode @default(ALL)

  commentFacultyMode ForumAccessMode @default(ALL)
  commentStudentMode ForumAccessMode @default(ALL)

  createdById String
  createdBy   User   @relation("ForumCategoryCreatedBy", fields: [createdById], references: [id])

  permissionUsers ForumCategoryUser[]
  threads         ForumThread[]

  @@index([batchId])
  @@index([courseId])
}

model ForumCategoryUser {
  id String @id @default(uuid())

  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  purpose ForumPermissionPurpose

  @@unique([categoryId, userId, purpose])
}

model ForumThread {
  id        String   @id @default(uuid())
  title     String
  body      String
  pinned    Boolean  @default(false)
  locked    Boolean  @default(false)
  createdAt DateTime @default(now())

  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  posts ForumPost[]
  likes ForumThreadLike[]

  @@index([categoryId])
}

model ForumPost {
  id        String   @id @default(uuid())
  body      String
  createdAt DateTime @default(now())

  threadId String
  thread   ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@index([threadId])
}

model ForumThreadLike {
  id String @id @default(uuid())

  threadId String
  thread   ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([threadId, userId])
}

model Subscription {
  id          String   @id @default(uuid())
  title       String   @unique
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses     SubscriptionCourse[]
  tests       SubscriptionTest[]
  enrollments SubscriptionEnrollment[]
}

model SubscriptionCourse {
  id String @id @default(uuid())

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, courseId])
}

model SubscriptionTest {
  id String @id @default(uuid())

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, testId])
}

model SubscriptionEnrollment {
  id String @id @default(uuid())

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  enrolledAt DateTime @default(now())

  @@unique([subscriptionId, studentId])
}

// ===================== Answer Correction =====================

model AnswerQuestionType {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facultyId String
  faculty   User   @relation("FacultyAnswerQuestionTypes", fields: [facultyId], references: [id])

  parts     AnswerQuestionTypePart[]
  questions AnswerQuestion[]
}

model AnswerQuestionTypePart {
  id            String @id @default(uuid())
  partKey       String // stable slug, e.g. "intro" -- referenced by AnswerQuestionPart.partKey
  name          String
  order         Int    @default(0)
  defaultWeight Float  @default(0) // 0..1, defaults should sum to 1.0 across a type (UI-validated, not DB-enforced)

  typeId String
  type   AnswerQuestionType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@unique([typeId, partKey])
}

model AnswerQuestion {
  id          String   @id @default(uuid())
  text        String   @db.Text
  directive   String?
  maxMarks    Float
  modelAnswer String   @db.Text
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  facultyId String
  faculty   User   @relation("FacultyAnswerQuestions", fields: [facultyId], references: [id])

  typeId String
  type   AnswerQuestionType @relation(fields: [typeId], references: [id])

  parts           AnswerQuestionPart[]
  forbiddenPoints AnswerQuestionForbiddenPoint[]
  submissions     AnswerSubmission[]

  @@index([typeId])
}

model AnswerQuestionPart {
  id      String @id @default(uuid())
  partKey String // matches AnswerQuestionTypePart.partKey for this question's type
  name    String
  order   Int    @default(0)
  marks   Float  // this part's share of maxMarks; sum of all parts' marks must == question.maxMarks

  questionId String
  question   AnswerQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  mustIncludePoints AnswerQuestionPoint[]      @relation("PartMustInclude")
  groups            AnswerQuestionPointGroup[]

  @@unique([questionId, partKey])
}

/// Standalone must_include points directly under a part (outside any "any N of M" group).
model AnswerQuestionPoint {
  id    String @id @default(uuid())
  text  String @db.Text
  marks Float

  partId String?
  part   AnswerQuestionPart? @relation("PartMustInclude", fields: [partId], references: [id], onDelete: Cascade)

  groupId String?
  group   AnswerQuestionPointGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([partId])
  @@index([groupId])
}

/// "Any N of M" group: minRequired points (out of points.length) must be present; marks = group's pool.
model AnswerQuestionPointGroup {
  id          String @id @default(uuid())
  minRequired Int
  marks       Float // total marks available for satisfying minRequired points in this group

  partId String
  part   AnswerQuestionPart @relation(fields: [partId], references: [id], onDelete: Cascade)

  points AnswerQuestionPoint[]
}

enum ForbiddenPointPenaltyType {
  NUMERIC
  FLAG_HARD
}

model AnswerQuestionForbiddenPoint {
  id          String                    @id @default(uuid())
  text        String                    @db.Text
  category    String
  penaltyType ForbiddenPointPenaltyType @default(NUMERIC)
  penalty     Float                     @default(0) // ignored/0 when penaltyType = FLAG_HARD

  questionId String
  question   AnswerQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

enum AnswerSubmissionStatus {
  PROCESSING
  GRADED
  FAILED
}

model AnswerSubmission {
  id           String                 @id @default(uuid())
  fileKey      String // R2 key of the uploaded photo/PDF (private bucket, presigned GET)
  fileType     String // mime type, e.g. "image/jpeg" | "application/pdf"
  status       AnswerSubmissionStatus @default(PROCESSING)
  errorMessage String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  questionId String
  question   AnswerQuestion @relation(fields: [questionId], references: [id])

  studentId String
  student   User   @relation("AnswerSubmissions", fields: [studentId], references: [id])

  evaluation AnswerEvaluation?

  @@index([questionId])
  @@index([studentId])
}

model AnswerEvaluation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  submissionId String           @unique
  submission   AnswerSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  // Transcript: ordered lines, kept for evidence/quoting (no bbox/page-geometry -- v1 is single-file, text only)
  transcript Json // TranscriptLine[] = { lineId: number; text: string }[]

  marksAwarded Float
  marksMax     Float
  verdict      String @db.Text

  parts          Json // PartResult[]
  forbiddenFound Json // ForbiddenHit[]
  bonusPoints    Json // BonusPoint[]

  modelAnswerRef String @db.Text // copy of the question's modelAnswer at grading time
  upgradedAnswer String @db.Text

  rawModelOutput Json? // full parsed LLM JSON, kept for debugging/audit -- nullable

  // Manual override layer -- FACULTY/ADMIN only. Null = AI result stands as-is.
  manualMarksAwarded Float?
  manualComment      String?   @db.Text
  manualGradedById   String?
  manualGradedBy     User?     @relation("AnswerEvaluationGradedBy", fields: [manualGradedById], references: [id])
  manualGradedAt     DateTime?
}

// One rating per student per course (upserted). Powers avgRating/reviewCount on courses.
model CourseReview {
  id        String   @id @default(uuid())
  rating    Int      // 1..5
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@index([courseId])
}

// Faculty/Admin notes, grouped into banks. A bank is shared with one or more batches;
// a student sees a bank's notes if they're enrolled in any of its batches.
model NotesBank {
  id        String   @id @default(uuid())
  title     String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String
  createdBy   User   @relation("CreatedNotesBanks", fields: [createdById], references: [id])

  notes   Note[]
  batches NotesBankBatch[]
}

model NotesBankBatch {
  notesBankId String
  notesBank   NotesBank @relation(fields: [notesBankId], references: [id], onDelete: Cascade)
  batchId     String
  batch       Batch     @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@id([notesBankId, batchId])
  @@index([batchId])
}

model Note {
  id        String   @id @default(uuid())
  name      String
  fileUrl   String   // private R2 key; presigned on read
  fileName  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notesBankId String
  notesBank   NotesBank @relation(fields: [notesBankId], references: [id], onDelete: Cascade)

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  chapterId String?
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([notesBankId])
  @@index([courseId])
}

// A dated study-plan item. Owned by EITHER a batch (faculty/admin timetable) OR a student
// (personal plan). The linked resource is denormalized (resourceKind/resourceId/courseId) so
// deleting a lesson/note/test never breaks the plan — the frontend builds the click-through URL.
model StudyPlanItem {
  id           String       @id @default(uuid())
  scheduledFor DateTime
  type         PlanItemType @default(OTHER)
  title        String
  resourceKind String? // 'lesson' | 'note' | 'test' | 'workout' | null
  resourceId   String?
  courseId     String? // context for building the resource URL
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  createdById String
  createdBy   User   @relation("PlanItemCreatedBy", fields: [createdById], references: [id])

  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  studentId String?
  student   User?   @relation("PlanItemStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([studentId])
  @@index([scheduledFor])
}
